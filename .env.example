# --- Backend wiring -----------------------------------------------------------
# The UI runs on demo data unless VITE_API_URL is set (enables the real backend).
#
# Same-origin production (Worker serves both the SPA and /api): set VITE_API_URL=/
# Separate API origin: point these at it.
# VITE_API_URL=https://api.example.com
# VITE_WEBSOCKET_URL=wss://api.example.com/realtime
#
# When Cloudflare Access fronts the app it injects auth automatically and no
# operator token is needed. For LOCAL dev (no Access), set VITE_OPERATOR_TOKEN to
# the same value as OPERATOR_API_TOKEN in .dev.vars so REST + realtime authenticate.
#
# Local dev (npm run dev:local on :8788 + npm run dev on :5173):
# VITE_API_URL=http://localhost:8788
# VITE_WEBSOCKET_URL=ws://localhost:8788/realtime
# VITE_OPERATOR_TOKEN=devop

VITE_JURISDICTION_ID=metro-central
